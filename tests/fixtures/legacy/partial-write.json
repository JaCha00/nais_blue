{
  "case": "partial-write",
  "description": "An incomplete v2 write cannot displace a valid legacy record.",
  "input": {
    "legacyRecord": {
      "schemaVersion": 1,
      "revision": 7,
      "profileName": "synthetic-old-profile"
    },
    "v2Record": {
      "schemaVersion": 2,
      "revision": 8,
      "profileName": "synthetic-v2-profile",
      "commitState": "partial"
    },
    "writeState": "partial"
  },
  "expected": {
    "readSource": "legacy",
    "writeTarget": "v2",
    "legacyRetained": true,
    "outcome": "fallback-read"
  }
}
