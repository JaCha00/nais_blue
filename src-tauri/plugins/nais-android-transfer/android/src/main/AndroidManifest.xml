<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Notifications make every user-started large transfer visible and controllable. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Android 14+ uses quota-exempt user-initiated data transfer jobs. -->
    <uses-permission android:name="android.permission.RUN_USER_INITIATED_JOBS" />
    <!-- API 24-33 WorkManager fallback runs as an explicit data-sync foreground service. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application>
        <service
            android:name=".NaisTransferJobService"
            android:exported="false"
            android:permission="android.permission.BIND_JOB_SERVICE" />

        <receiver
            android:name=".TransferActionReceiver"
            android:exported="false" />

        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />
    </application>
</manifest>
