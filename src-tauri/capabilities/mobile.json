{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile-main",
  "description": "Mobile main window access limited to app-scoped files and NAIS2 network services",
  "platforms": ["android", "iOS"],
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-stat",
    "fs:allow-read",
    "fs:allow-read-file",
    "fs:allow-write",
    "fs:allow-write-file",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-remove",
    "fs:allow-rename",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPDATA/**"
        }
      ]
    },
    "http:allow-fetch",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://api.novelai.net/*"
        },
        {
          "url": "https://image.novelai.net/*"
        }
      ]
    },
    "store:default",
    "dialog:default",
    "opener:default",
    "process:allow-restart",
    "deep-link:default"
  ]
}
