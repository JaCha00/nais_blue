{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window with FS and HTTP access",
  "platforms": ["windows", "linux", "macOS"],
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-start-dragging",
    "core:window:allow-is-maximized",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-read-dir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-picture-read-recursive",
    "fs:allow-picture-write-recursive",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$PICTURE/**"
        },
        {
          "path": "$PICTURE/**/.*"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$APPDATA/**/.*"
        },
        {
          "path": "$LOCALAPPDATA/**"
        },
        {
          "path": "$LOCALAPPDATA/**/.*"
        }
      ]
    },
    "http:allow-fetch",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://api.novelai.net/*"
        },
        {
          "url": "https://image.novelai.net/*"
        }
      ]
    },
    "store:default",
    "dialog:default",
    "opener:default",
    "updater:default",
    "process:allow-restart",
    "stronghold:allow-initialize",
    "stronghold:allow-create-client",
    "stronghold:allow-load-client",
    "stronghold:allow-get-store-record",
    "stronghold:allow-save-store-record",
    "stronghold:allow-remove-store-record",
    "stronghold:allow-save",
    "stronghold:allow-destroy"
  ]
}
