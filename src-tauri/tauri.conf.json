{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NAIS2",
  "version": "2.8.2",
  "identifier": "com.bluhair.naisblue",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:9090",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NAIS2 - NovelAI Image Studio",
        "width": 1600,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$PICTURE/**",
          "$APPDATA/**",
          "$LOCALAPPDATA/**"
        ]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/JaCha00/nais_blue/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEwMUFGMDgxMDY4NEYyRTEKUldUaDhvUUdnZkFhb0RqeVMyOWZ4QXlJVnFyVlZiVDVibHd0bDRUbTRFeTU2TVBGYzdPK0t3UXUK"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi",
      "dmg",
      "app"
    ],
    "externalBin": [
      "binaries/tagger-server"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": null,
      "exceptionDomain": null
    },
    "windows": {
      "nsis": {
        "installMode": "both",
        "installerHooks": "nsis/installer-hooks.nsh"
      }
    }
  }
}
