{
  "name": "nais2",
  "version": "2.8.1",
  "license": "GPL-3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mobile": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test:responsive-layout": "node scripts/verify-responsive-layout-contract.mjs",
    "test:remote-runtime-removal": "node scripts/verify-remote-runtime-removal.mjs",
    "test:smart-tools": "node scripts/test-smart-tools-contract.mjs",
    "test:nai-core": "node scripts/verify-nai-core-phase.mjs",
    "test:unit": "vitest run tests/helpers",
    "test:payload-parity": "vitest run tests/payload-parity tests/fixtures/provenance.test.ts",
    "test:composition": "vitest run",
    "test:migration": "vitest run tests/migration",
    "test:diagnostics": "vitest run tests/diagnostics",
    "test:nai-transport": "vitest run tests/transport",
    "test:persistence": "vitest run tests/persistence && node scripts/verify-rescue-mode.mjs",
    "test:secret-redaction": "node scripts/verify-secret-redaction.mjs",
    "test:credential-vault": "vitest run tests/credentials",
    "test:characterization": "vitest run tests/characterization",
    "test:android-port": "node scripts/verify-android-port-contract.mjs",
    "test:release-version": "node scripts/verify-release-version.mjs",
    "test:android-idle": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/track-android-idle.ps1",
    "smoke:nai-subscription": "node scripts/smoke-nai-subscription.mjs",
    "smoke:nai-endpoints": "node scripts/smoke-nai-endpoints.mjs",
    "smoke:nai-client": "vitest run tests/live/nai-client-live.test.ts",
    "tauri": "npx tauri",
    "tauri:dev": "npx tauri dev",
    "tauri:build": "npx tauri build",
    "tauri:android:init": "npx tauri android init",
    "tauri:android:dev": "npx tauri android dev --host 0.0.0.0",
    "tauri:android:build:apk": "npx tauri android build --apk",
    "tauri:android:build:aab": "npx tauri android build --aab",
    "android:prepare": "node scripts/prepare-android-release.mjs",
    "test:android-release-contract": "node scripts/verify-android-release-contract.mjs",
    "test:android-release": "node scripts/verify-android-apk.mjs --mode release",
    "test:android-debug": "node scripts/verify-android-apk.mjs --mode debug",
    "release:android:apk": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-android.ps1",
    "release:android:github": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-android.ps1 -Publish",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
